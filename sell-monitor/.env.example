# Provider selection
# akshare: AkShare realtime + BaoStock historical bars when baostock is installed, then AkShare fallback
# baostock: require BaoStock historical bars; realtime quote still uses AkShare
SELL_MONITOR_PROVIDER=akshare

# SMTP email alerts
SELL_MONITOR_SMTP_HOST=smtp.example.com
SELL_MONITOR_SMTP_PORT=587
SELL_MONITOR_SMTP_USERNAME=you@example.com
SELL_MONITOR_SMTP_PASSWORD=your-app-password
SELL_MONITOR_SMTP_USE_TLS=true
SELL_MONITOR_EMAIL_FROM=you@example.com
SELL_MONITOR_EMAIL_TO=you@example.com
SELL_MONITOR_EMAIL_SUBJECT_PREFIX=[SellMonitor]

# Obsidian sell output
# Default sell note path:
# E:\tools\OB\Obsidian\Trade\notes\monitor\sell
SELL_MONITOR_OBSIDIAN_MONITOR_ENABLED=true
SELL_MONITOR_OBSIDIAN_MONITOR_DIR=E:\tools\OB\Obsidian\Trade\notes\monitor\sell

# Obsidian entry output + watchlist
# Default entry note path:
# E:\tools\OB\Obsidian\Trade\notes\monitor\entry
# Default watchlist path:
# E:\tools\OB\Obsidian\Trade\notes\monitor\config\watchlist.json
SELL_MONITOR_OBSIDIAN_ENTRY_ENABLED=true
SELL_MONITOR_OBSIDIAN_ENTRY_DIR=E:\tools\OB\Obsidian\Trade\notes\monitor\entry
SELL_MONITOR_OBSIDIAN_WATCHLIST_PATH=E:\tools\OB\Obsidian\Trade\notes\monitor\config\watchlist.json
SELL_MONITOR_WATCHLIST_PATH=E:\tools\OB\Obsidian\Trade\notes\monitor\config\watchlist.json
SELL_MONITOR_POSITIONS_PATH=E:\tools\OB\Obsidian\Trade\notes\monitor\config\positions.json
SELL_MONITOR_USER_RULES_PATH=E:\tools\OB\Obsidian\Trade\notes\monitor\config\user_rules.json
SELL_MONITOR_MARKET_DATA_PATH=C:\Users\admin\Documents\New project\sell-monitor\examples\market_data.json

# Optional alternate .env location
# SELL_MONITOR_ENV_FILE=E:\tools\OB\Obsidian\Trade\notes\monitor\config\sell-monitor.env
