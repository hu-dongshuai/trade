# Provider selection
# akshare: AkShare realtime + BaoStock historical bars when baostock is installed, then AkShare fallback
# baostock: require BaoStock historical bars; realtime quote still uses AkShare
SELL_MONITOR_PROVIDER=akshare

# SMTP email alerts
SELL_MONITOR_SMTP_HOST=smtp.example.com
SELL_MONITOR_SMTP_PORT=587
SELL_MONITOR_SMTP_USERNAME=you@example.com
SELL_MONITOR_SMTP_PASSWORD=your-app-password
SELL_MONITOR_SMTP_USE_TLS=true
SELL_MONITOR_EMAIL_FROM=you@example.com
SELL_MONITOR_EMAIL_TO=you@example.com
SELL_MONITOR_EMAIL_SUBJECT_PREFIX=[SellMonitor]

# Obsidian monitor output
# Default monitor note path currently in use:
# E:\tools\OB\Obsidian\Trade\notes\monitor
SELL_MONITOR_OBSIDIAN_MONITOR_ENABLED=true
SELL_MONITOR_OBSIDIAN_MONITOR_DIR=E:\tools\OB\Obsidian\Trade\notes\monitor

# Optional alternate .env location
# SELL_MONITOR_ENV_FILE=C:\path\to\sell-monitor\.env
